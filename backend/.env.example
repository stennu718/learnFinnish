# learnFinnish environment configuration
# Copy this file to .env and fill in the values

# Database
DATABASE_URL=sqlite+aiosqlite:///./learnfinnish.db

# JWT
# Generate a strong key with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=generate-a-strong-key-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8081"]
